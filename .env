# --- LLM Provider ---
# LLM_PROVIDER selects which client app/llm/factory.py builds: "azure_openai" (default) or "deepseek".
LLM_PROVIDER=azure_openai

# Azure OpenAI - get these from the Azure AI Foundry / Azure OpenAI Studio resource you deployed a model to.
# AZURE_OPENAI_ENDPOINT format: https://<your-resource-name>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT is the deployment name you chose when deploying the model (not the base model name).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

# DeepSeek (used only if LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Auth ---
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Storage ---
SQLITE_DB_PATH=../storage/nbc_platform.db
CHROMA_PERSIST_DIR=../storage/chroma
DOCUMENTS_DIR=../storage/documents
GENERATED_DIR=../storage/generated

# --- Application Explorer browser drivers (optional manual override) ---
# Selenium Manager auto-downloads a matching driver by default, which needs outbound internet
# access to Microsoft's/Google's driver-hosting endpoints and can fail (wrong cached version, or
# a DNS error on a locked-down network). If that happens: check installed browser version
# (edge://version or chrome://version), download the EXACT matching driver from
# https://developer.microsoft.com/en-us/microsoft-edge/tools/webdriver/ (Edge) or
# https://googlechromelabs.github.io/chrome-for-testing/ (Chrome), extract it anywhere, and point
# these at the .exe.
CHROME_DRIVER_PATH=
EDGE_DRIVER_PATH=F:\NBC_project\tools\msedgedriver\msedgedriver.exe
